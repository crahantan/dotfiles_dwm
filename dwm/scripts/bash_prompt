# Script bash PROMPT

# Colores ANSI
RESET="\033[0m"
BOLD="\033[1m"
GRAY="\033[1;90m"  # Gris en negrita
GREEN="\033[1;32m" # Verde en negrita
YELLOW="\033[1;33m" # Amarillo en negrita
RED="\033[1;31m"   # Rojo en negrita

# Función para obtener el estado de Git
get_git_status() {
    local branch status
    branch=$(git branch --show-current 2>/dev/null)
    if [ -n "$branch" ]; then
        # Verificar el estado del repositorio usando git status --porcelain
        status=$(git status --porcelain 2>/dev/null)
        if [ -z "$status" ]; then
            echo -e "${GREEN}(${branch})${RESET}:${GREEN}"  # Repositorio limpio (verde)
        elif echo "$status" | grep -q '^[MADRC]'; then
            echo -e "${YELLOW}(${branch}+)${RESET}:${YELLOW}"  # Cambios en el staging area (amarillo)
        else
            echo -e "${RED}(${branch}*)${RESET}:${RED}"  # Cambios sin stage (rojo)
        fi
    else
        echo ":${GRAY}"  # No es un repositorio Git (flecha gris)
    fi
}

# Función para actualizar el prompt dinámicamente
update_prompt() {
    local git_status
    git_status=$(get_git_status)
    # Separar el estado de Git y el color de la flecha
    IFS=':' read -r git_info arrow_color <<< "$git_status"
    PS1="${BOLD}${GRAY}\u${RESET} ${git_info}${BOLD}${arrow_color}->${RESET} "  # Prompt con colores
}

# Configurar PROMPT_COMMAND para llamar a update_prompt antes de cada prompt
PROMPT_COMMAND='update_prompt'

